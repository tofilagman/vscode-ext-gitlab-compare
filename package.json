{
  "name": "git-branch-compare",
  "displayName": "Git Branch Compare",
  "description": "Compare two git branches visually with a merge-request-style diff — file tree, commits, and multi-file diffs. No merge request required.",
  "version": "0.3.0",
  "publisher": "tofilagman",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tofilagman/vscode-ext-gitlab-compare.git"
  },
  "bugs": {
    "url": "https://github.com/tofilagman/vscode-ext-gitlab-compare/issues"
  },
  "homepage": "https://github.com/tofilagman/vscode-ext-gitlab-compare#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "diff",
    "compare",
    "branch",
    "merge request",
    "code review"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "branchCompare",
          "title": "Branch Compare",
          "icon": "media/compare.svg"
        }
      ]
    },
    "views": {
      "branchCompare": [
        {
          "id": "branchCompare.changes",
          "name": "Changes",
          "icon": "media/compare.svg",
          "contextualTitle": "Branch Compare"
        },
        {
          "id": "branchCompare.commits",
          "name": "Commits",
          "icon": "media/compare.svg",
          "contextualTitle": "Branch Compare"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "branchCompare.changes",
        "contents": "Compare two git branches and browse the changes in a merge-request-style diff.\n[Open compare page](command:branchCompare.selectBranches)\nThe target is the base branch; the source is the branch whose changes you want to review."
      },
      {
        "view": "branchCompare.commits",
        "contents": "Commits on the source branch that aren't in the target will appear here.\n[Open compare page](command:branchCompare.selectBranches)",
        "when": "!branchCompare.hasComparison"
      }
    ],
    "commands": [
      {
        "command": "branchCompare.selectBranches",
        "title": "Branch Compare: Open Compare Page",
        "icon": "$(git-compare)"
      },
      {
        "command": "branchCompare.refresh",
        "title": "Branch Compare: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "branchCompare.swapBranches",
        "title": "Branch Compare: Swap Target / Source",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "branchCompare.toggleCompareMode",
        "title": "Branch Compare: Toggle Merge-base / Direct Diff",
        "icon": "$(git-merge)"
      },
      {
        "command": "branchCompare.openChange",
        "title": "Branch Compare: Open Change"
      },
      {
        "command": "branchCompare.openCommitChange",
        "title": "Branch Compare: Open Commit Change"
      },
      {
        "command": "branchCompare.openCommitDiff",
        "title": "View Entire Commit as One Diff",
        "icon": "$(diff-multiple)"
      },
      {
        "command": "branchCompare.openAllChanges",
        "title": "Branch Compare: View All Changes as One Diff",
        "icon": "$(diff-multiple)"
      },
      {
        "command": "branchCompare.copyCommitSha",
        "title": "Copy Commit SHA",
        "icon": "$(copy)"
      },
      {
        "command": "branchCompare.viewAsList",
        "title": "Branch Compare: View as List",
        "icon": "$(list-flat)"
      },
      {
        "command": "branchCompare.viewAsTree",
        "title": "Branch Compare: View as Tree",
        "icon": "$(list-tree)"
      },
      {
        "command": "branchCompare.openFile",
        "title": "Open File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "branchCompare.copyPath",
        "title": "Copy Relative Path"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "branchCompare.selectBranches",
          "when": "view == branchCompare.changes",
          "group": "navigation@1"
        },
        {
          "command": "branchCompare.swapBranches",
          "when": "view == branchCompare.changes && branchCompare.hasComparison",
          "group": "navigation@2"
        },
        {
          "command": "branchCompare.viewAsList",
          "when": "view == branchCompare.changes && branchCompare.hasComparison && branchCompare.treeLayout",
          "group": "navigation@3"
        },
        {
          "command": "branchCompare.viewAsTree",
          "when": "view == branchCompare.changes && branchCompare.hasComparison && !branchCompare.treeLayout",
          "group": "navigation@3"
        },
        {
          "command": "branchCompare.toggleCompareMode",
          "when": "view == branchCompare.changes && branchCompare.hasComparison",
          "group": "navigation@4"
        },
        {
          "command": "branchCompare.openAllChanges",
          "when": "view == branchCompare.changes && branchCompare.hasComparison",
          "group": "navigation@5"
        },
        {
          "command": "branchCompare.refresh",
          "when": "view == branchCompare.changes && branchCompare.hasComparison",
          "group": "navigation@6"
        },
        {
          "command": "branchCompare.selectBranches",
          "when": "view == branchCompare.commits",
          "group": "navigation@1"
        },
        {
          "command": "branchCompare.refresh",
          "when": "view == branchCompare.commits && branchCompare.hasComparison",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "branchCompare.openCommitDiff",
          "when": "view == branchCompare.commits && viewItem == commit",
          "group": "inline@1"
        },
        {
          "command": "branchCompare.copyCommitSha",
          "when": "view == branchCompare.commits && viewItem == commit",
          "group": "inline@2"
        },
        {
          "command": "branchCompare.openCommitDiff",
          "when": "view == branchCompare.commits && viewItem == commit",
          "group": "navigation@1"
        },
        {
          "command": "branchCompare.openFile",
          "when": "view == branchCompare.changes && viewItem == file",
          "group": "inline@1"
        },
        {
          "command": "branchCompare.openFile",
          "when": "view == branchCompare.commits && viewItem == commitFile",
          "group": "inline@1"
        },
        {
          "command": "branchCompare.openFile",
          "when": "view == branchCompare.changes && viewItem == file || view == branchCompare.commits && viewItem == commitFile",
          "group": "navigation@1"
        },
        {
          "command": "branchCompare.copyPath",
          "when": "view == branchCompare.changes && viewItem == file || view == branchCompare.commits && viewItem == commitFile",
          "group": "1_copy@1"
        }
      ]
    },
    "configuration": {
      "title": "Branch Compare",
      "properties": {
        "branchCompare.compareMode": {
          "type": "string",
          "enum": [
            "merge-base",
            "direct"
          ],
          "enumDescriptions": [
            "Three-dot diff (target...source): only changes introduced on the source branch since it diverged. Matches how a merge request shows changes.",
            "Two-dot diff (target source): every difference between the two branch tips."
          ],
          "default": "merge-base",
          "description": "How to compute the diff between the two branches."
        },
        "branchCompare.showRemoteBranches": {
          "type": "boolean",
          "default": true,
          "description": "Include remote-tracking branches in the branch picker."
        },
        "branchCompare.maxCommits": {
          "type": "number",
          "default": 500,
          "minimum": 0,
          "description": "Maximum number of commits to list in the Commits view. Set to 0 for no limit."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.4.0"
  }
}
